# ============================================================
# .env — SQL Server Connection Settings
# Copy this file as .env and fill in your details
# ============================================================

SQL_SERVER=localhost
SQL_DATABASE=HeartDiseaseDB
SQL_DRIVER=ODBC Driver 17 for SQL Server
SQL_TRUSTED=yes

# If using SQL Authentication instead of Windows Auth:
# SQL_TRUSTED=no
# SQL_USER=your_username
# SQL_PASSWORD=your_password

# Path to the raw CSV source file
CSV_SOURCE_PATH=./data/heart_2020_cleaned.csv
